    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dexie": "^4.4.2",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.5.0",
